# Database (Use 'postgres' for Docker, 'localhost' for local development)
DATABASE_URL=postgresql+asyncpg://handwerker_user:handwerker_password@postgres:5432/handwerker_platform
DATABASE_URL_SYNC=postgresql://handwerker_user:handwerker_password@postgres:5432/handwerker_platform

# Redis (Use 'redis' for Docker, 'localhost' for local development)
REDIS_URL=redis://redis:6379/0

# Application
SECRET_KEY=your-secret-key-change-this-in-production
ENVIRONMENT=development
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000

# Authentication
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@handwerker-platform.de

# Stripe (Payment)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PLATFORM_FEE_PERCENTAGE=15.0

# File Upload
MAX_UPLOAD_SIZE=5242880  # 5MB
UPLOAD_DIR=uploads/
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp

# Business
COMMISSION_RATE=0.15  # 15% platform commission
MINIMUM_BOOKING_HOURS=1
CANCELLATION_HOURS=24  # Hours before booking to allow cancellation
